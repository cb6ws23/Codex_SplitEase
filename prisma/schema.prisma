generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Group {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  currency       String    @default("JPY")
  writeTokenHash String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  members        Member[]
  expenses       Expense[]
}

model Member {
  id         String               @id @default(cuid())
  groupId    String
  name       String
  sortOrder  Int
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  group      Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidExpenses Expense[]          @relation("ExpensePayer")
  splits     ExpenseParticipant[]

  @@index([groupId, sortOrder])
}

model Expense {
  id             String               @id @default(cuid())
  groupId        String
  title          String
  notes          String?
  amount         Decimal              @db.Decimal(12, 0)
  paidByMemberId String
  happenedOn     DateTime
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  group          Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidByMember   Member               @relation("ExpensePayer", fields: [paidByMemberId], references: [id], onDelete: Restrict)
  participants   ExpenseParticipant[]

  @@index([groupId, happenedOn])
  @@index([paidByMemberId])
}

model ExpenseParticipant {
  id        String   @id @default(cuid())
  expenseId String
  memberId  String
  createdAt DateTime @default(now())
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([expenseId, memberId])
  @@index([memberId])
}
